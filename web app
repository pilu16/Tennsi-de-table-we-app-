<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🏓 Conseiller Matériel Tennis de Table</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ===== RESET & VARIABLES ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy:        #0d1b2e;
  --navy-mid:    #1a3350;
  --navy-light:  #234980;
  --orange:      #ff5f1f;
  --orange-dark: #e04d10;
  --orange-glow: rgba(255,95,31,.18);
  --blue:        #3b9eff;
  --blue-light:  #e8f4ff;
  --green:       #10b981;
  --purple:      #8b5cf6;
  --gold:        #f59e0b;
  --bg:          #f0f4f8;
  --card:        #ffffff;
  --text:        #0d1b2e;
  --text-mid:    #374151;
  --muted:       #6b7280;
  --border:      #e5e7eb;
  --radius-sm:   8px;
  --radius:      14px;
  --radius-lg:   20px;
  --shadow:      0 2px 12px rgba(13,27,46,.08);
  --shadow-md:   0 6px 24px rgba(13,27,46,.12);
  --shadow-lg:   0 12px 48px rgba(13,27,46,.18);
}
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.5;
}

/* ===== HEADER ===== */
.app-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1e3f70 100%);
  padding: 1.25rem 1.5rem 1.5rem;
  position: relative;
  overflow: hidden;
}
.app-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 20% 50%, rgba(255,95,31,.15) 0%, transparent 50%),
                    radial-gradient(circle at 80% 20%, rgba(59,158,255,.1) 0%, transparent 40%);
  pointer-events: none;
}
.app-header::after {
  content: '🏓';
  position: absolute;
  right: -10px; top: -10px;
  font-size: 9rem;
  opacity: .05;
  transform: rotate(-20deg);
  pointer-events: none;
}
.header-inner {
  max-width: 960px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 1rem;
  position: relative;
  z-index: 1;
}
.header-icon {
  background: var(--orange);
  width: 46px; height: 46px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(255,95,31,.4);
}
.header-text h1 {
  font-size: 1.2rem;
  font-weight: 800;
  color: white;
  letter-spacing: -.02em;
}
.header-text p {
  font-size: .78rem;
  color: rgba(255,255,255,.6);
  margin-top: .1rem;
}

/* ===== CONTAINER ===== */
.container {
  max-width: 960px;
  margin: 0 auto;
  padding: 1.75rem 1rem 3rem;
}

/* ===== STEP PROGRESS ===== */
.progress-wrap {
  margin-bottom: 2rem;
}
.steps-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: .75rem;
  gap: 0;
}
.step-dot {
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 2px solid var(--border);
  background: white;
  display: flex; align-items: center; justify-content: center;
  font-size: .72rem;
  font-weight: 700;
  color: var(--muted);
  transition: all .3s ease;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.step-dot.done {
  background: var(--navy);
  border-color: var(--navy);
  color: white;
}
.step-dot.active {
  background: var(--orange);
  border-color: var(--orange);
  color: white;
  box-shadow: 0 0 0 4px var(--orange-glow);
}
.step-line {
  flex: 1;
  height: 2px;
  background: var(--border);
  max-width: 60px;
  transition: background .3s;
}
.step-line.done { background: var(--navy); }
.progress-label {
  text-align: center;
  font-size: .8rem;
  font-weight: 500;
  color: var(--muted);
}
.progress-label span { color: var(--navy); font-weight: 700; }

/* ===== QUIZ CARD ===== */
.quiz-step { display: none; }
.quiz-step.active { display: block; animation: stepIn .35s cubic-bezier(.22,1,.36,1) both; }
.quiz-step.leaving { animation: stepOut .25s ease forwards; }

@keyframes stepIn {
  from { opacity: 0; transform: translateX(28px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes stepOut {
  from { opacity: 1; transform: translateX(0); }
  to   { opacity: 0; transform: translateX(-24px); }
}
@keyframes stepBackIn {
  from { opacity: 0; transform: translateX(-28px); }
  to   { opacity: 1; transform: translateX(0); }
}

.quiz-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 2rem;
  box-shadow: var(--shadow-md);
  border: 1px solid rgba(255,255,255,.8);
}
.quiz-card .step-badge {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  background: var(--blue-light);
  color: var(--blue);
  font-size: .72rem;
  font-weight: 700;
  padding: .25rem .7rem;
  border-radius: 99px;
  margin-bottom: .9rem;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.quiz-card h2 {
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: .4rem;
  letter-spacing: -.02em;
}
.quiz-card .subtitle {
  color: var(--muted);
  font-size: .88rem;
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

/* ===== OPTION BUTTONS ===== */
.options-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: .75rem;
  margin-bottom: .25rem;
}
.option-btn {
  border: 2px solid var(--border);
  background: var(--card);
  border-radius: var(--radius);
  padding: 1.1rem 1rem;
  cursor: pointer;
  text-align: left;
  transition: all .2s cubic-bezier(.22,1,.36,1);
  position: relative;
  overflow: hidden;
}
.option-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--orange-glow), transparent);
  opacity: 0;
  transition: opacity .2s;
}
.option-btn:hover {
  border-color: var(--orange);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}
.option-btn:hover::before { opacity: 1; }
.option-btn.selected {
  border-color: var(--orange);
  background: white;
  box-shadow: 0 0 0 3px var(--orange-glow), var(--shadow-md);
}
.option-btn.selected::before { opacity: 1; }
.option-btn .check-mark {
  position: absolute;
  top: .6rem; right: .6rem;
  width: 20px; height: 20px;
  background: var(--orange);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .65rem;
  color: white;
  opacity: 0;
  transform: scale(0);
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.option-btn.selected .check-mark { opacity: 1; transform: scale(1); }
.option-icon {
  width: 42px; height: 42px;
  border-radius: 10px;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem;
  margin-bottom: .7rem;
  transition: background .2s;
}
.option-btn.selected .option-icon,
.option-btn:hover .option-icon { background: rgba(255,95,31,.12); }
.option-btn strong {
  display: block;
  font-size: .92rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: .2rem;
}
.option-btn small {
  color: var(--muted);
  font-size: .75rem;
  line-height: 1.4;
  display: block;
}

/* ===== CHECKBOXES ===== */
.check-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: .5rem;
}
.check-btn {
  border: 2px solid var(--border);
  background: var(--card);
  border-radius: var(--radius-sm);
  padding: .7rem .9rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: .6rem;
  transition: all .18s;
  font-size: .85rem;
  color: var(--text-mid);
}
.check-btn:hover { border-color: var(--navy-light); background: #f8fafc; }
.check-btn.selected { border-color: var(--navy); background: var(--blue-light); color: var(--navy); }
.cb {
  width: 20px; height: 20px;
  border: 2px solid var(--border);
  border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: .75rem;
  transition: all .15s;
  background: white;
}
.check-btn.selected .cb {
  background: var(--navy);
  border-color: var(--navy);
  color: white;
}

/* ===== SLIDERS ===== */
.sliders-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem 1.5rem;
}
@media (max-width: 540px) { .sliders-grid { grid-template-columns: 1fr; } }
.slider-group { }
.slider-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: .4rem;
}
.slider-name {
  font-size: .88rem;
  font-weight: 600;
  color: var(--navy);
  display: flex;
  align-items: center;
  gap: .35rem;
}
.slider-val {
  background: var(--navy);
  color: white;
  font-size: .75rem;
  font-weight: 700;
  padding: .2rem .55rem;
  border-radius: 99px;
  min-width: 32px;
  text-align: center;
  transition: background .2s;
}
.slider-hints {
  display: flex;
  justify-content: space-between;
  font-size: .65rem;
  color: var(--muted);
  margin-top: .25rem;
}
input[type=range] {
  width: 100%;
  height: 6px;
  appearance: none;
  -webkit-appearance: none;
  background: var(--border);
  border-radius: 99px;
  outline: none;
  cursor: pointer;
}
input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--navy);
  border: 3px solid white;
  box-shadow: 0 2px 8px rgba(0,0,0,.2);
  cursor: pointer;
  transition: transform .15s;
}
input[type=range]::-webkit-slider-thumb:hover { transform: scale(1.15); }
input[type=range].orange::-webkit-slider-thumb { background: var(--orange); }
input[type=range].blue::-webkit-slider-thumb   { background: var(--blue); }
input[type=range].green::-webkit-slider-thumb  { background: var(--green); }
input[type=range].purple::-webkit-slider-thumb { background: var(--purple); }
/* Firefox */
input[type=range]::-moz-range-thumb {
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--navy);
  border: 3px solid white;
  box-shadow: 0 2px 8px rgba(0,0,0,.2);
  cursor: pointer;
}
input[type=range]::-moz-range-track { background: var(--border); height: 6px; border-radius: 99px; }

/* ===== NAV BUTTONS ===== */
.nav-btns {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 1.75rem;
  gap: .75rem;
}
.btn {
  border: none;
  border-radius: var(--radius-sm);
  padding: .7rem 1.5rem;
  font-size: .9rem;
  font-weight: 700;
  cursor: pointer;
  transition: all .18s;
  font-family: inherit;
  display: inline-flex;
  align-items: center;
  gap: .4rem;
}
.btn-primary {
  background: var(--navy);
  color: white;
}
.btn-primary:hover:not(:disabled) {
  background: var(--navy-light);
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}
.btn-primary:disabled { background: #d1d5db; color: #9ca3af; cursor: not-allowed; }
.btn-secondary {
  background: transparent;
  color: var(--muted);
  border: 2px solid var(--border);
}
.btn-secondary:hover { border-color: var(--navy); color: var(--navy); background: var(--blue-light); }
.btn-cta {
  background: linear-gradient(135deg, var(--orange) 0%, var(--orange-dark) 100%);
  color: white;
  padding: .75rem 1.75rem;
  font-size: .95rem;
  border-radius: var(--radius-sm);
  box-shadow: 0 4px 16px rgba(255,95,31,.35);
}
.btn-cta:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255,95,31,.45);
}
.btn-cta:disabled { background: #d1d5db; color: #9ca3af; box-shadow: none; cursor: not-allowed; }

/* ===== RESULTS ===== */
#results { display: none; }
#results.visible { display: block; animation: fadeUp .4s ease both; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.results-hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
  border-radius: var(--radius-lg);
  padding: 1.5rem 1.75rem;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.results-hero h2 {
  font-size: 1.15rem;
  font-weight: 800;
  color: white;
  margin-bottom: .3rem;
}
.results-hero p {
  color: rgba(255,255,255,.6);
  font-size: .82rem;
  line-height: 1.5;
}
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: .4rem;
  margin-top: .5rem;
}
.hero-tag {
  background: rgba(255,255,255,.12);
  color: rgba(255,255,255,.85);
  font-size: .72rem;
  font-weight: 600;
  padding: .25rem .65rem;
  border-radius: 99px;
  border: 1px solid rgba(255,255,255,.15);
}
.btn-reset {
  background: rgba(255,255,255,.12);
  color: white;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: var(--radius-sm);
  padding: .6rem 1.1rem;
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .18s;
  font-family: inherit;
  white-space: nowrap;
}
.btn-reset:hover { background: rgba(255,255,255,.2); }

.section-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: .5rem;
}
.section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.results-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 1rem;
}

/* ===== PROFILE CARD ===== */
.profile-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
  border: 2px solid transparent;
  transition: transform .2s ease, box-shadow .2s ease;
  animation: cardIn .4s ease both;
}
.profile-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.profile-card.best-match {
  border-color: var(--orange);
}
@keyframes cardIn {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.profile-card:nth-child(1) { animation-delay: .05s; }
.profile-card:nth-child(2) { animation-delay: .12s; }
.profile-card:nth-child(3) { animation-delay: .19s; }
.profile-card:nth-child(4) { animation-delay: .26s; }

.profile-header {
  padding: 1.1rem 1.2rem .9rem;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
  position: relative;
  overflow: hidden;
}
.profile-header.color-orange { background: linear-gradient(135deg, #7c2d12 0%, var(--orange-dark) 100%); }
.profile-header.color-blue   { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); }
.profile-header.color-green  { background: linear-gradient(135deg, #064e3b 0%, #059669 100%); }
.profile-header.color-purple { background: linear-gradient(135deg, #2e1065 0%, #7c3aed 100%); }
.profile-header::after {
  content: attr(data-icon);
  position: absolute;
  right: -.5rem; bottom: -.5rem;
  font-size: 5rem;
  opacity: .12;
  pointer-events: none;
}
.ph-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: .5rem;
  margin-bottom: .6rem;
}
.ph-left { flex: 1; }
.ph-title {
  font-size: 1rem;
  font-weight: 800;
  color: white;
  letter-spacing: -.01em;
  line-height: 1.2;
}
.ph-sub {
  font-size: .72rem;
  color: rgba(255,255,255,.6);
  margin-top: .2rem;
}
.best-badge {
  background: var(--orange);
  color: white;
  font-size: .65rem;
  font-weight: 700;
  padding: .2rem .55rem;
  border-radius: 99px;
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: .05em;
  flex-shrink: 0;
}
.price-tag {
  font-size: .9rem;
  font-weight: 800;
  color: white;
  background: rgba(255,255,255,.15);
  display: inline-flex;
  align-items: center;
  gap: .25rem;
  padding: .3rem .7rem;
  border-radius: 99px;
  border: 1px solid rgba(255,255,255,.2);
}

/* Match bar */
.match-row {
  display: flex;
  align-items: center;
  gap: .6rem;
  background: rgba(255,255,255,.1);
  border-radius: 8px;
  padding: .4rem .65rem;
}
.match-label { font-size: .7rem; color: rgba(255,255,255,.7); flex-shrink: 0; }
.match-track {
  flex: 1;
  height: 5px;
  background: rgba(255,255,255,.2);
  border-radius: 99px;
  overflow: hidden;
}
.match-fill {
  height: 100%;
  background: white;
  border-radius: 99px;
  width: 0;
  transition: width .8s cubic-bezier(.22,1,.36,1);
}
.match-pct {
  font-size: .78rem;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
  min-width: 32px;
  text-align: right;
}

/* Profile body */
.profile-body {
  padding: 1rem 1.2rem;
}
.why-text {
  font-size: .8rem;
  color: var(--muted);
  line-height: 1.55;
  margin-bottom: .9rem;
  padding-bottom: .9rem;
  border-bottom: 1px solid var(--border);
}
.stat-bars { margin-bottom: .9rem; }
.stat-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  margin-bottom: .35rem;
}
.stat-name {
  font-size: .7rem;
  color: var(--muted);
  width: 52px;
  flex-shrink: 0;
}
.stat-track {
  flex: 1;
  height: 6px;
  background: var(--border);
  border-radius: 99px;
  overflow: hidden;
}
.stat-fill {
  height: 100%;
  border-radius: 99px;
  width: 0;
  transition: width .7s cubic-bezier(.22,1,.36,1);
}
.stat-num {
  font-size: .7rem;
  font-weight: 700;
  color: var(--text-mid);
  width: 24px;
  text-align: right;
  flex-shrink: 0;
}

/* Pros/cons */
.pros-cons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .5rem;
  margin-bottom: .9rem;
}
@media (max-width: 360px) { .pros-cons { grid-template-columns: 1fr; } }
.pros, .cons {
  border-radius: var(--radius-sm);
  padding: .6rem .75rem;
}
.pros { background: #f0fdf4; border: 1px solid #bbf7d0; }
.cons { background: #fff7ed; border: 1px solid #fed7aa; }
.pros h5 { color: #15803d; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .35rem; }
.cons h5 { color: #c2410c; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .35rem; }
.pros ul, .cons ul { list-style: none; }
.pros li { font-size: .73rem; line-height: 1.45; color: #166534; padding-left: .9rem; position: relative; }
.cons li { font-size: .73rem; line-height: 1.45; color: #9a3412; padding-left: .9rem; position: relative; }
.pros li::before { content: "✓"; position: absolute; left: 0; font-weight: 700; }
.cons li::before { content: "✗"; position: absolute; left: 0; font-weight: 700; }

/* Products section */
.products-section { }
.prod-section-title {
  display: flex;
  align-items: center;
  gap: .4rem;
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--muted);
  margin-bottom: .45rem;
  margin-top: .6rem;
}
.prod-section-title:first-child { margin-top: 0; }
.product-row {
  background: #f8fafc;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: .65rem .8rem;
  margin-bottom: .4rem;
  cursor: pointer;
  transition: all .18s;
}
.product-row:hover {
  border-color: var(--navy-light);
  background: var(--blue-light);
  transform: translateX(2px);
}
.pr-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: .5rem;
}
.pr-name { font-size: .83rem; font-weight: 700; color: var(--navy); }
