function buildProfiles() {
  const isDebutant = state.niveau === 'debutant';
  const isIntermediaire = state.niveau === 'intermediaire';
  const isConfirme = ['confirme','avance'].includes(state.niveau);
  const profiles = [];

  if (isDebutant) {
    profiles.push(...buildDebutantProfiles());
  } else if (isIntermediaire) {
    profiles.push(...buildIntermediaireProfiles());
  } else {
    profiles.push(...buildConfirmeProfiles());
  }

  // Trier par score de correspondance
  profiles.sort((a,b) => b.matchScore - a.matchScore);
  return profiles.slice(0,4);
}

function scoreMatch(profile) {
  let score = 0;
  const w = { vitesse: state.vitesse, controle: state.controle, spin: state.spin, puissance: state.puissance };
  if (profile.speed) score += (profile.speed/10) * w.vitesse;
  if (profile.control) score += (profile.control/10) * w.controle;
  if (profile.spin) score += (profile.spin/10) * w.spin;
  score = Math.round((score / (w.vitesse+w.controle+w.spin+w.puissance)) * 100);
  return Math.min(score, 99);
}

function budgetOk(price) {
  const b = state.budget;
  if (b === 'petit') return price <= 55;
  if (b === 'moyen') return price <= 130;
  if (b === 'confortable') return price <= 260;
  return true;
}

