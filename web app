function findBlade(type1, type2, type3, maxPrice, preferCarbon) {
  let candidates = BLADES.filter(b => {
    const typeMatch = b.type===type1 || b.type===type2 || b.type===type3;
    const priceMatch = !maxPrice || b.price <= maxPrice;
    return typeMatch && priceMatch;
  });
  if (preferCarbon) candidates = candidates.filter(b => b.layers.includes('carbon') || b.layers.includes('ALC') || b.layers.includes('ZLC'));
  if (candidates.length === 0) candidates = BLADES.filter(b => b.price <= (maxPrice||999));
  // Pick best match based on user priorities
  candidates.sort((a,b) => {
    const scoreA = (a.speed/10)*state.vitesse + (a.control/10)*state.controle;
    const scoreB = (b.speed/10)*state.vitesse + (b.control/10)*state.controle;
    return scoreB - scoreA;
  });
  return candidates[0] || null;
}

function findRubber(categ, priority, maxPrice) {
  let candidates = RUBBERS.filter(r => {
    const categMatch = r.categ === categ;
    const priceMatch = !maxPrice || r.priceRange <= maxPrice;
    return categMatch && priceMatch && r.type === 'inverted' && r.ittf;
  });
  if (candidates.length === 0) candidates = RUBBERS.filter(r => r.type==='inverted' && r.ittf);
  if (priority === 'spin') candidates.sort((a,b) => b.spin - a.spin);
  else if (priority === 'speed') candidates.sort((a,b) => b.speed - a.speed);
  else candidates.sort((a,b) => b.control - a.control);
  return candidates[0] || null;
}

function findRubberByBrand(brand, type, categ, priority) {
  let candidates = RUBBERS.filter(r => {
    return (!brand || r.brand===brand) && (!type || r.type===type) && (!categ || r.categ===categ) && r.ittf;
  });
  if (priority === 'spin') candidates.sort((a,b) => b.spin - a.spin);
  else candidates.sort((a,b) => b.speed - a.speed);
  return candidates[0] || null;
}

