    <div class="options-grid" style="margin-bottom:1.2rem;grid-template-columns:1fr 1fr">
      <button class="option-btn" onclick="selectMainHand('droitier',this)">
        <div class="check-mark">✓</div>
        <div class="option-icon">🤜</div>
        <strong>Droitier</strong>
      </button>
      <button class="option-btn" onclick="selectMainHand('gaucher',this)">
        <div class="check-mark">✓</div>
        <div class="option-icon">🤛</div>
        <strong>Gaucher</strong>
      </button>
    </div>
    <p style="font-size:.82rem;color:var(--muted);font-weight:600;margin-bottom:.6rem;text-transform:uppercase;letter-spacing:.05em">${state.style==='defenseur' ? 'Type de défense' : 'Caractéristiques (optionnel)'}</p>
    <div class="check-grid">
      ${state.style==='defenseur' ? `
        <button class="check-btn" onclick="toggleCheck('specialites','chop',this)"><div class="cb"></div><span>🪓 Chop loin de la table</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','block',this)"><div class="cb"></div><span>🛡️ Bloc près de la table</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','longpips_def',this)"><div class="cb"></div><span>📌 Picots longs (BH)</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','antispin_def',this)"><div class="cb"></div><span>🚫 Anti-spin</span></button>
      ` : `
        <button class="check-btn" onclick="toggleCheck('specialites','fh_dominant',this)"><div class="cb"></div><span>✋ FH dominant</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','bh_topspin',this)"><div class="cb"></div><span>🔄 BH topspin</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','jeu_court',this)"><div class="cb"></div><span>📍 Jeu court / service</span></button>
        <button class="check-btn" onclick="toggleCheck('specialites','midist',this)"><div class="cb"></div><span>↔️ Mi-distance</span></button>
      `}
    </div>`;
}

function selectMainHand(val, btn) {
  state.main = val;
  const grid = btn.closest('.options-grid');
  grid.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
}

function nextStep(from) {
  if (from === 1 && !state.niveau) return;
  if (from === 2 && !state.style) return;
  if (from === 2) buildStep3();
  const curEl = document.getElementById('step'+from);
  curEl.classList.add('leaving');
  setTimeout(() => {
    curEl.classList.remove('active','leaving');
    currentStep = from + 1;
    const next = document.getElementById('step'+currentStep);
    next.classList.add('active');
    updateProgress();
    window.scrollTo({top:0, behavior:'smooth'});
  }, 200);
}

function prevStep(current) {
  const curEl = document.getElementById('step'+current);
  curEl.style.animation = 'stepOut .2s ease forwards';
  setTimeout(() => {
    curEl.style.animation = '';
    curEl.classList.remove('active');
    currentStep = current - 1;
    const prev = document.getElementById('step'+currentStep);
    prev.classList.add('active');
    prev.style.animation = 'stepBackIn .3s ease both';
    setTimeout(()=>{ prev.style.animation=''; }, 300);
    updateProgress();
    window.scrollTo({top:0, behavior:'smooth'});
  }, 180);
}

// ============================================================
//  RESULTS
// ============================================================
function generateResults() {
  document.getElementById('quiz').style.display = 'none';
  const r = document.getElementById('results');
  r.style.display = 'block';
  r.classList.add('visible');

  // Hero
  const levelL = {debutant:'Débutant',intermediaire:'Intermédiaire',confirme:'Confirmé',avance:'Avancé'};
  const styleL = {defenseur:'Défenseur 🛡️',allround:'All-Round ⚖️',attaquant:'Attaquant ⚡',topspin:'Topspin 🌀'};
  const budgetL = {petit:'< 50 €',moyen:'50–120 €',confortable:'120–250 €',premium:'250 €+'};
  document.getElementById('heroDesc').textContent =
    `${levelL[state.niveau]} · ${styleL[state.style]} · Budget ${budgetL[state.budget]}`;
  const tags = document.getElementById('heroTags');
  tags.innerHTML = [
    `V:${state.vitesse}/10`,
    `Ctrl:${state.controle}/10`,
    `Spin:${state.spin}/10`,
    `Puis:${state.puissance}/10`
  ].map(t => `<span class="hero-tag">${t}</span>`).join('');

  const profiles = buildProfiles();
  renderProfiles(profiles);
}

// ============================================================
//  RENDER
// ============================================================
const PROFILE_COLORS = ['color-blue','color-orange','color-purple','color-green'];
const PROFILE_ICONS = { '⚡':'⚡', '🌀':'🌀', '⚖️':'⚖️', '🛡️':'🛡️', '🏓':'🏓', '💶':'💶' };

function renderProfiles(profiles) {
  const grid = document.getElementById('resultsGrid');
  grid.innerHTML = '';

  profiles.forEach((p, i) => {
    const isBest = i === 0;
    const colorClass = PROFILE_COLORS[i % 4];
    const totalPrice = p.type === 'complete'
      ? `~${p.price} €`
      : `~${((p.blade?.price||0) + (p.rubberFH?.priceRange||0)*2)} €`;

    let productsHTML = '';
    if (p.type === 'complete') {
      productsHTML = `
        <div class="prod-section-title">🏓 Raquette complète</div>
        ${productCardHTML(p.products[0])}`;
    } else {
      productsHTML = `
        <div class="prod-section-title">🏓 Lame</div>
        ${p.blade ? bladeCardHTML(p.blade) : ''}
        <div class="prod-section-title">🔴 Coup droit (FH)</div>
        ${p.rubberFH ? rubberCardHTML(p.rubberFH) : ''}
        <div class="prod-section-title">🔵 Revers (BH)</div>
        ${p.rubberBH ? rubberCardHTML(p.rubberBH, p.rubberFH?.id===p.rubberBH?.id) : ''}`;
    }

    const speedPct  = Math.round(((p.speed||5)/10)*100);
    const ctrlPct   = Math.round(((p.control||5)/10)*100);
    const spinPct   = Math.round(((p.spin||5)/10)*100);
    const matchPct  = p.matchScore;

    grid.innerHTML += `
      <div class="profile-card ${isBest?'best-match':''}">
        <div class="profile-header ${colorClass}" data-icon="${p.icon}">
          <div class="ph-top">
            <div class="ph-left">
              <div class="ph-title">${p.icon} ${p.title}</div>
              <div class="ph-sub">${p.subtitle}</div>
            </div>
            ${isBest ? '<span class="best-badge">⭐ Meilleur match</span>' : ''}
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;margin-top:.5rem">
            <div class="match-row" style="flex:1">
              <span class="match-label">Match</span>
              <div class="match-track"><div class="match-fill" data-pct="${matchPct}"></div></div>
              <span class="match-pct">${matchPct}%</span>
            </div>
            <div class="price-tag">${totalPrice}</div>
          </div>
        </div>
        <div class="profile-body">
          <p class="why-text">${p.why}</p>
          <div class="stat-bars">
            <div class="stat-row">
              <span class="stat-name">Vitesse</span>
              <div class="stat-track"><div class="stat-fill" style="background:var(--orange)" data-pct="${speedPct}"></div></div>
              <span class="stat-num">${(p.speed||5).toFixed(1)}</span>
            </div>
            <div class="stat-row">
              <span class="stat-name">Contrôle</span>
              <div class="stat-track"><div class="stat-fill" style="background:var(--green)" data-pct="${ctrlPct}"></div></div>
              <span class="stat-num">${(p.control||5).toFixed(1)}</span>
            </div>
            <div class="stat-row">
              <span class="stat-name">Spin</span>
              <div class="stat-track"><div class="stat-fill" style="background:var(--purple)" data-pct="${spinPct}"></div></div>
              <span class="stat-num">${(p.spin||5).toFixed(1)}</span>
            </div>
          </div>
          <div class="pros-cons">
            <div class="pros"><h5>✓ Pour</h5><ul>${p.pros.map(x=>`<li>${x}</li>`).join('')}</ul></div>
            <div class="cons"><h5>✗ Limites</h5><ul>${p.cons.map(x=>`<li>${x}</li>`).join('')}</ul></div>
          </div>
          <div class="products-section">${productsHTML}</div>
        </div>
      </div>`;
  });

  // Animate bars after DOM update
  requestAnimationFrame(() => {
    setTimeout(() => {
      document.querySelectorAll('.match-fill[data-pct]').forEach(el => {
        el.style.width = el.dataset.pct + '%';
      });
      document.querySelectorAll('.stat-fill[data-pct]').forEach(el => {
        el.style.width = el.dataset.pct + '%';
      });
    }, 150);
  });
}

function bladeCardHTML(b) {
  return `<div class="product-row" onclick="showModal('blade','${b.id}')">
    <div class="pr-top">
      <div>
        <div class="pr-name">${b.name}</div>
        <div class="pr-brand">${b.brand} · ${b.layers} · ${b.type}</div>
      </div>
      <div class="pr-price">~${b.price} €</div>
    </div>
    <div class="pr-tags">
      <span class="pr-tag spd">V ${b.speed}</span>
      <span class="pr-tag ctl">Ctrl ${b.control}</span>
      <span class="pr-tag def">${b.stiffness}</span>
    </div>
  </div>`;
}

function rubberCardHTML(r, isSame) {
  return `<div class="product-row" onclick="showModal('rubber','${r.id}')">
    <div class="pr-top">
      <div>
        <div class="pr-name">${r.name}${isSame?' <span style="font-size:.65rem;color:var(--muted)">(idem FH)</span>':''}</div>
        <div class="pr-brand">${r.brand} · ${typeLabel(r.type)} · ${r.hardness}</div>
      </div>
      <div class="pr-price">~${r.priceRange} €</div>
    </div>
    <div class="pr-tags">
      <span class="pr-tag spd">V ${r.speed}</span>
      <span class="pr-tag spi">S ${r.spin}</span>
      <span class="pr-tag ctl">C ${r.control}</span>
      ${r.ittf ? '<span class="pr-tag ittf">✅ ITTF</span>' : ''}
    </div>
  </div>`;
}

function productCardHTML(r) {
  return `<div class="product-row">
    <div class="pr-top">
      <div>
        <div class="pr-name">${r.name}</div>
        <div class="pr-brand">${r.brand} · Raquette complète prête à jouer</div>
      </div>
      <div class="pr-price">~${r.priceRange} €</div>
    </div>
    <div class="pr-tags">
      <span class="pr-tag spd">V ${r.speed}</span>
      <span class="pr-tag ctl">C ${r.control}</span>
      <span class="pr-tag spi">S ${r.spin}</span>
    </div>
  </div>`;
}

function typeLabel(t) {
  return {inverted:'Lisse',shortpips:'Picots courts',longpips:'Picots longs',antispin:'Anti-spin'}[t]||t;
}

// ============================================================
//  MODAL
// ============================================================
function showModal(type, id) {
  const item = type==='blade' ? BLADES.find(b=>b.id===id) : RUBBERS.find(r=>r.id===id);
  if (!item) return;
  let html = '';
  if (type === 'blade') {
    html = `<div class="modal-head">
      <button class="modal-close" onclick="closeModal()">✕</button>
      <h3>🏓 ${item.name}</h3>
      <div class="modal-brand">${item.brand} · Lame · ${item.layers}</div>
    </div>
    <div class="modal-body">
      <div class="modal-stats">
        <div class="mstat"><div class="mstat-val">${item.speed}</div><div class="mstat-lbl">Vitesse</div></div>
        <div class="mstat"><div class="mstat-val">${item.control}</div><div class="mstat-lbl">Contrôle</div></div>
        <div class="mstat"><div class="mstat-val" style="font-size:.9rem">${item.stiffness}</div><div class="mstat-lbl">Rigidité</div></div>
      </div>
      <p class="modal-desc">${item.desc}</p>
      <div class="modal-tags">
        <span class="pr-tag def">~${item.price} €</span>
        <span class="pr-tag def">${item.type}</span>
        <span class="pr-tag def">${item.layers}</span>
      </div>
    </div>`;
  } else {
    html = `<div class="modal-head">
      <button class="modal-close" onclick="closeModal()">✕</button>
      <h3>${item.name}</h3>
      <div class="modal-brand">${item.brand} · ${typeLabel(item.type)} · Éponge ${item.hardness}</div>
    </div>
    <div class="modal-body">
      ${item.ittf ? '<span class="ittf-badge">✅ Homologué ITTF Compétition</span>' : ''}
      <div class="modal-stats">
        <div class="mstat"><div class="mstat-val">${item.speed}</div><div class="mstat-lbl">Vitesse</div></div>
        <div class="mstat"><div class="mstat-val">${item.spin}</div><div class="mstat-lbl">Spin</div></div>
        <div class="mstat"><div class="mstat-val">${item.control}</div><div class="mstat-lbl">Contrôle</div></div>
      </div>
      <p class="modal-desc">${item.desc}</p>
      <div class="modal-tags">
        <span class="pr-tag def">~${item.priceRange} € / revêt.</span>
        <span class="pr-tag def">${item.hardness}</span>
      </div>
    </div>`;
  }
  document.getElementById('modalContent').innerHTML = html;
  document.getElementById('modalOverlay').classList.add('open');
  // Animate modal stats bars
  requestAnimationFrame(() => {
    setTimeout(() => {
      document.querySelectorAll('#modalContent .match-fill[data-pct]').forEach(el => {
        el.style.width = el.dataset.pct + '%';
      });
    }, 100);
  });
}

function closeModal(e) {
  if (!e || e.target === document.getElementById('modalOverlay')) {
    document.getElementById('modalOverlay').classList.remove('open');
  }
}

function resetQuiz() {
  const r = document.getElementById('results');
  r.style.display = 'none';
  r.classList.remove('visible');
  document.getElementById('quiz').style.display = 'block';
  currentStep = 1;
  Object.assign(state, {niveau:null,style:null,main:null,specialites:[],faibles:[],vitesse:5,controle:5,spin:5,puissance:5,budget:null});
  document.querySelectorAll('.quiz-step').forEach(s => s.classList.remove('active','leaving'));
  document.getElementById('step1').classList.add('active');
  document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
  document.querySelectorAll('.check-btn').forEach(b => { b.classList.remove('selected'); b.querySelector('.cb').innerHTML=''; });
  document.querySelectorAll('[id^=next]').forEach(b => b.disabled = true);
  ['vitesse','controle','spin','puissance'].forEach(f => {
    document.getElementById('sl_'+f).value = 5;
    document.getElementById('val_'+f).textContent = '5';
  });
  updateProgress();
  window.scrollTo({top:0, behavior:'smooth'});
}


