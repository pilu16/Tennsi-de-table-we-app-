function selectOption(field, val, btn) {
  state[field] = val;
  const parent = btn.closest('.options-grid');
  parent.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  const stepNum = btn.closest('.quiz-step').id.replace('step','');
  const nb = document.getElementById('next'+stepNum);
  if (nb) nb.disabled = false;
}

function toggleCheck(field, val, btn) {
  btn.classList.toggle('selected');
  const cb = btn.querySelector('.cb');
  if (btn.classList.contains('selected')) {
    if (!state[field].includes(val)) state[field].push(val);
    cb.innerHTML = '✓';
  } else {
    state[field] = state[field].filter(v => v !== val);
    cb.innerHTML = '';
  }
}

function updateSlider(field, val) {
  state[field] = parseInt(val);
  document.getElementById('val_'+field).textContent = val;
}

function updateProgress() {
  for (let i = 1; i <= 6; i++) {
    const dot = document.getElementById('sdot'+i);
    dot.classList.remove('active','done');
    if (i < currentStep) dot.classList.add('done');
    else if (i === currentStep) dot.classList.add('active');
    if (i < 6) {
      const line = document.getElementById('sline'+i);
      line.classList.toggle('done', i < currentStep);
    }
  }
  const lbl = document.getElementById('stepLabel');
  lbl.innerHTML = `Étape <span>${currentStep}</span> sur 6 — ${stepLabels[currentStep-1]}`;
}

